# Copy to .env (or export these) to configure the admin panel.

# Port/host the admin panel listens on.
PORT=3000
HOST=0.0.0.0

# Base URL of the cubeplane engine control API (see [control] in cubeplane.toml).
ENGINE_URL=http://127.0.0.1:8080

# If the engine sets control.token, put the same value here so the panel can
# authenticate server-side (it is never exposed to the browser).
ENGINE_TOKEN=
